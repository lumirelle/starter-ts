{
  "name": "pkg-placeholder",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "aube@1.17.1",
  "description": "_description_",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/pkg-placeholder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/pkg-placeholder.git"
  },
  "bugs": "https://github.com/lumirelle/pkg-placeholder/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">22",
    "bun": ">1"
  },
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3"
      },
      "build": {
        "tsdown": "^0.22.1"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/core": "^0.18.3",
        "@lumirelle/oxlint-config": "^0.7.0",
        "eslint": "^10.4.1",
        "eslint-plugin-oxlint": "^1.68.0",
        "knip": "^6.15.0",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.68.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.8",
        "tsnapi": "^0.3.3",
        "vitest": "^4.1.8"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "mise run prepare",
    "dev": "tsdown --tsconfig tsconfig.lib.json --watch",
    "build": "tsdown --tsconfig tsconfig.lib.json --publint --attw.profile esm-only",
    "start": "bun run ./src/index.ts",
    "oxlint": "oxlint --config .oxlintrc.json",
    "eslint": "eslint",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/core": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:test",
    "bumpp": "catalog:dev",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "tsdown": "catalog:build",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types",
    "vitest": "catalog:test"
  },
  "overrides": {
    "typescript": "catalog:types"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
