{
  "name": "pkg-placeholder",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.14",
  "description": "_description_",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/pkg-placeholder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/pkg-placeholder.git"
  },
  "bugs": "https://github.com/lumirelle/pkg-placeholder/issues",
  "keywords": [],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": {
    "packages": [],
    "catalogs": {
      "self": {
        "pkg-placeholder": "file:."
      },
      "dev": {
        "bumpp": "^11.1.0"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.7.0",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "build": {
        "bunup": "^0.16.31"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.4.0",
        "eslint": "^10.3.0",
        "eslint-plugin-oxlint": "^1.64.0",
        "knip": "^6.13.1",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.64.0",
        "oxlint-tsgolint": "^0.22.1",
        "publint": "^0.3.21",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      },
      "test": {
        "tsnapi": "^0.3.3"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunup --watch",
    "build": "bunup --exports",
    "start": "bun run ./src/index.ts",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "bunup": "catalog:build",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "pkg-placeholder": "catalog:self",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:check",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types"
  },
  "overrides": {
    "typescript": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
