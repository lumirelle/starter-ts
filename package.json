{
  "name": "pkg-placeholder",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.11",
  "description": "_description_",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/pkg-placeholder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/pkg-placeholder.git"
  },
  "bugs": "https://github.com/lumirelle/pkg-placeholder/issues",
  "keywords": [],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": {
    "packages": [],
    "catalogs": {
      "inlined": {
        "@antfu/utils": "^9.3.0"
      },
      "dev": {
        "bumpp": "^11.0.1",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "typescript": "^5.9.3"
      },
      "types": {
        "@types/bun": "^1.3.11"
      },
      "build": {
        "bunup": "^0.16.31"
      },
      "check": {
        "@antfu/eslint-config": "^7.7.3",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.0.3",
        "eslint": "^10.0.3",
        "eslint-plugin-oxlint": "^1.56.0",
        "knip": "^5.88.0",
        "nano-staged": "^0.9.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "^0.17.0",
        "publint": "^0.3.18"
      },
      "test": {
        "vitest-package-exports": "^1.2.0"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunup --watch",
    "build": "bunup --exports",
    "start": "bun run ./src/index.ts",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc --noEmit",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@antfu/utils": "catalog:inlined",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@types/bun": "catalog:types",
    "bumpp": "catalog:dev",
    "bunup": "catalog:build",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "pkg-placeholder": "file:.",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest-package-exports": "catalog:test"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint",
      "eslint"
    ]
  }
}
