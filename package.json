      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3"
      },
      "build": {
        "tsdown": "^0.22.3"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/cli": "^0.18.4",
        "@lumirelle/oxlint-config": "^0.9.1",
        "eslint": "^10.5.0",
        "eslint-plugin-oxlint": "^1.70.0",
        "knip": "^6.17.1",
        "oxlint": "^1.70.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.9",
        "tsnapi": "^0.3.3",
        "vitest": "^4.1.9"
      },
      "release": {
        "bumpp": "^11.1.0",
        "changelogithub": "^14.0.0",
        "npm": "^11.17.0",
        "pkg-pr-new": "^0.0.75"
      }
    }
  },
